# App process
APP_ENV=development
SERVICE_NAME=explorer-api
PORT=8080
LOG_LEVEL=info
HTTP_HEALTH_TIMEOUT=2s
SHUTDOWN_TIMEOUT=10s

# Local infrastructure
NATS_CLIENT_PORT=4222
NATS_MONITOR_PORT=8222
POSTGRES_PORT=5432
FRONTEND_PORT=5173

# Postgres bootstrap
POSTGRES_DB=explorer
POSTGRES_USER=explorer
POSTGRES_PASSWORD=explorer

# App connection strings
NATS_URL=nats://localhost:4222
NATS_CLIENT_NAME=explorer-api
POSTGRES_DSN=postgres://explorer:explorer@localhost:5432/explorer?sslmode=disable
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_RESPONSES_WS_URL=wss://api.openai.com/v1/responses
OPENAI_DIAL_TIMEOUT=10s
OPENAI_READ_TIMEOUT=65s
OPENAI_WRITE_TIMEOUT=10s
OPENAI_PING_INTERVAL=30s
OPENAI_MAX_MESSAGE_BYTES=16777216
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=
OPENAI_API_KEY=
WORKER_ID=

# Local blob storage
BLOB_STORAGE_DIR=./blob-storage
